name: Contribution Chart
on:
  schedule:
    - cron: '0 0 * * *'
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-python@v4
        with:
          python-version: '3.11'
      - run: pip install requests matplotlib numpy
      - run: python scripts/gen_chart.py
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GH_USERNAME: h4x-Shivam
      - uses: actions/upload-artifact@v3
        with:
          name: chart
          path: assets/contribution-chart.png
      - run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add assets/contribution-chart.png
          git diff --cached --quiet || git commit -m "chore: update contribution chart"
          git push
